# CamelClaw Environment Variables (Example)
# Copy this to .env and adjust values as needed.

# GCP Vertex AI Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Local AI Configuration (Optional)
LOCAL_API_URL=http://localhost:8080/v1/chat/completions
GEMINI_LOCAL_TOKEN=your-local-api-token

# Model Selection
GEMINI_MODEL=gemini-2.0-flash-001

# ESP-IDF Configuration
# Path to your ESP-IDF installation (containing export.sh)
IDF_PATH=/home/user/esp/v5.5.1
# Root directory for your projects
PROJECTS_ROOT=/home/user/camelclaw/projects
